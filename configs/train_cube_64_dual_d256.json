{
    "dataset": {
        "repo_id": "piper/cube_64_dual",
        "root": "/home/huatec/piper_act_bottle_grasp/data/cube_64_dual",
        "episodes": null,
        "image_transforms": {
            "enable": true,
            "max_num_transforms": 3,
            "random_order": false,
            "tfs": {
                "brightness": {
                    "weight": 1.0,
                    "type": "ColorJitter",
                    "kwargs": { "brightness": [0.8, 1.2] }
                },
                "contrast": {
                    "weight": 1.0,
                    "type": "ColorJitter",
                    "kwargs": { "contrast": [0.8, 1.2] }
                },
                "saturation": {
                    "weight": 1.0,
                    "type": "ColorJitter",
                    "kwargs": { "saturation": [0.5, 1.5] }
                },
                "hue": {
                    "weight": 1.0,
                    "type": "ColorJitter",
                    "kwargs": { "hue": [-0.05, 0.05] }
                },
                "sharpness": {
                    "weight": 1.0,
                    "type": "SharpnessJitter",
                    "kwargs": { "sharpness": [0.5, 1.5] }
                },
                "affine": {
                    "weight": 1.0,
                    "type": "RandomAffine",
                    "kwargs": { "degrees": [-5.0, 5.0], "translate": [0.05, 0.05] }
                }
            }
        },
        "use_imagenet_stats": true,
        "video_backend": "pyav",
        "return_uint8": false,
        "streaming": false
    },
    "policy": {
        "push_to_hub": false,
        "type": "act",
        "n_obs_steps": 1,
        "input_features": {
            "observation.state": { "type": "STATE", "shape": [7] },
            "observation.images.global_rgb": { "type": "VISUAL", "shape": [3, 480, 640] },
            "observation.images.wrist_rgb": { "type": "VISUAL", "shape": [3, 480, 640] }
        },
        "output_features": {
            "action": { "type": "ACTION", "shape": [7] }
        },
        "device": "cuda",
        "use_amp": false,
        "chunk_size": 10,
        "n_action_steps": 10,
        "normalization_mapping": {
            "VISUAL": "MEAN_STD",
            "STATE": "MEAN_STD",
            "ACTION": "MEAN_STD"
        },
        "vision_backbone": "resnet18",
        "pretrained_backbone_weights": "ResNet18_Weights.IMAGENET1K_V1",
        "dim_model": 256,
        "n_heads": 4,
        "dim_feedforward": 512,
        "feedforward_activation": "relu",
        "n_encoder_layers": 2,
        "n_decoder_layers": 2,
        "dropout": 0.0,
        "optimizer_lr": 0.0003,
        "optimizer_weight_decay": 0.0001,
        "optimizer_lr_backbone": 0.0001
    },
    "output_dir": "/home/huatec/piper_act_bottle_grasp/outputs/train/act_cube_64_dual_d256",
    "job_name": "act_cube_64_dual_d256",
    "seed": 1000,
    "num_workers": 0,
    "batch_size": 4,
    "prefetch_factor": 4,
    "steps": 15000,
    "log_freq": 100,
    "save_freq": 1000,
    "use_policy_training_preset": true,
    "optimizer": {
        "type": "adamw",
        "lr": 0.0003,
        "weight_decay": 0.0001,
        "grad_clip_norm": 10.0,
        "betas": [0.9, 0.999],
        "eps": 1e-08
    },
    "wandb": { "enable": false }
}
