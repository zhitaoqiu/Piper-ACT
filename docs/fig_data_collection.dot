digraph DataCollection {
    rankdir=TB
    fontname="Noto Sans CJK SC"
    fontsize=18
    label="采集数据流"
    labelloc=t
    newrank=true
    nodesep=0.4
    ranksep=0.6

    node [fontname="Noto Sans CJK SC" fontsize=11 style="rounded,filled" penwidth=1.5 shape=box]

    START [label="用户按空格" fillcolor="#F1948A" color="#E74C3C" shape=oval]
    THREAD [label="采集线程启动\n(30Hz)" fillcolor="#85C1E9" color="#2980B9"]

    subgraph cluster_loop {
        label="每帧循环 (30Hz)"
        fontname="Noto Sans CJK SC"
        fontsize=13
        style="rounded,dashed"
        color="#8E44AD"
        bgcolor="#F4ECF7"
        penwidth=2

        READ_J [label="读被控臂关节状态\n→ observation.state\n(7D float32)" fillcolor="#BB8FCE" color="#8E44AD"]
        READ_W [label="读腕部相机\n→ obs.images.wrist_rgb\n(480×640 BGR)" fillcolor="#BB8FCE" color="#8E44AD"]
        READ_G [label="读全局相机\n→ obs.images.global_rgb\n(480×640 BGR)" fillcolor="#BB8FCE" color="#8E44AD"]
        COMPUTE [label="action[t] = state[t+1]\n下一帧状态 = 当前动作目标" fillcolor="#F9E79F" color="#F1C40F"]
    }

    WRITE [label="写入 LeRobot 数据集\nstate/action → Parquet\n图像 → MP4 (AV1)" fillcolor="#82E0AA" color="#1E8449"]
    STOP [label="用户再按空格\n保存 episode" fillcolor="#F1948A" color="#E74C3C" shape=oval]

    START -> THREAD
    THREAD -> READ_J [style=invis]
    THREAD -> {READ_J, READ_W, READ_G} [color="#8E44AD" penwidth=1.5]
    READ_J -> COMPUTE [color="#F1C40F" penwidth=1.5]
    READ_W -> COMPUTE [color="#F1C40F" penwidth=1.5]
    READ_G -> COMPUTE [color="#F1C40F" penwidth=1.5]
    COMPUTE -> WRITE [color="#1E8449" penwidth=1.5 label=" 每帧写入" fontcolor="#1E8449" fontname="Noto Sans CJK SC" fontsize=10]
    WRITE -> STOP [color="#E74C3C" penwidth=1.5]
}
