digraph Architecture {
    rankdir=TB
    fontname="Noto Sans CJK SC"
    fontsize=20
    label="Piper ACT Bottle Grasp — 系统架构"
    labelloc=t
    newrank=true
    compound=true
    nodesep=0.6
    ranksep=0.5

    node [fontname="Noto Sans CJK SC" fontsize=11 style="rounded,filled" penwidth=1.5 shape=box]

    // --- 应用层 ---
    subgraph cluster_app {
        label="应用层"
        fontname="Noto Sans CJK SC"
        fontsize=14
        style="rounded,dashed"
        color="#E74C3C"
        bgcolor="#FDEDEC"
        penwidth=2

        A1 [label="teleop/data_collector.py\n采集示教数据" fillcolor="#F1948A" color="#E74C3C"]
        A2 [label="inference/deploy.py\n推理部署"             fillcolor="#F1948A" color="#E74C3C"]
    }

    // --- 算法层 ---
    subgraph cluster_alg {
        label="算法层"
        fontname="Noto Sans CJK SC"
        fontsize=14
        style="rounded,dashed"
        color="#8E44AD"
        bgcolor="#F4ECF7"
        penwidth=2

        B1 [label="LeRobot ACT Policy\n(ResNet18 + Transformer)" fillcolor="#BB8FCE" color="#8E44AD"]
        B2 [label="Normalization Pipeline\n(Mean/Std 归一化)"     fillcolor="#BB8FCE" color="#8E44AD"]
    }

    // --- 驱动层 ---
    subgraph cluster_drv {
        label="驱动层"
        fontname="Noto Sans CJK SC"
        fontsize=14
        style="rounded,dashed"
        color="#2980B9"
        bgcolor="#EBF5FB"
        penwidth=2

        C1 [label="hardware/piper_wrapper.py\nPiper SDK 封装" fillcolor="#85C1E9" color="#2980B9"]
        C2 [label="camera/rs_camera.py\n(RealSense + USB)"   fillcolor="#85C1E9" color="#2980B9"]
    }

    // --- 硬件抽象层 ---
    subgraph cluster_hal {
        label="硬件抽象层"
        fontname="Noto Sans CJK SC"
        fontsize=14
        style="rounded,dashed"
        color="#1E8449"
        bgcolor="#E9F7EF"
        penwidth=2

        D1 [label="piper_sdk_py_driver\n(CAN 通信)"       fillcolor="#82E0AA" color="#1E8449"]
        D2 [label="pyrealsense2 / OpenCV\n(相机采集)"      fillcolor="#82E0AA" color="#1E8449"]
    }

    // --- 物理硬件 ---
    subgraph cluster_hw {
        label="物理硬件"
        fontname="Noto Sans CJK SC"
        fontsize=14
        style="rounded,dashed"
        color="#7F8C8D"
        bgcolor="#F2F3F4"
        penwidth=2

        HW1 [label="Piper 机械臂\n(CAN 总线)"         fillcolor="#BDC3C7" color="#7F8C8D"]
        HW2 [label="RealSense D435i + USB 全局相机\n(USB 3.0)" fillcolor="#BDC3C7" color="#7F8C8D"]
    }

    // ===== 数据流 / 控制流 =====

    // 应用层 → 算法层
    A1 -> B1 [label="写入训练数据" color="#E67E22" fontcolor="#E67E22" fontname="Noto Sans CJK SC" fontsize=9]
    A2 -> B1 [label="加载推理"     color="#E67E22" fontcolor="#E67E22" fontname="Noto Sans CJK SC" fontsize=9]
    B1 -> B2 [label="调用"         color="#E67E22" fontcolor="#E67E22" fontname="Noto Sans CJK SC" fontsize=9]

    // 应用层 → 驱动层
    A1 -> C1 [label="控制" color="#E67E22" fontcolor="#E67E22" fontname="Noto Sans CJK SC" fontsize=9]
    A1 -> C2 [label="读取" color="#E67E22" fontcolor="#E67E22" fontname="Noto Sans CJK SC" fontsize=9]
    A2 -> C1 [label="控制" color="#E67E22" fontcolor="#E67E22" fontname="Noto Sans CJK SC" fontsize=9]
    A2 -> C2 [label="读取" color="#E67E22" fontcolor="#E67E22" fontname="Noto Sans CJK SC" fontsize=9]

    // 驱动层 → 硬件抽象层
    C1 -> D1 [label="封装" color="#E67E22" fontcolor="#E67E22" fontname="Noto Sans CJK SC" fontsize=9]
    C2 -> D2 [label="封装" color="#E67E22" fontcolor="#E67E22" fontname="Noto Sans CJK SC" fontsize=9]

    // 硬件抽象层 → 物理硬件
    D1 -> HW1 [label="CAN 总线" color="#27AE60" fontcolor="#27AE60" fontname="Noto Sans CJK SC" fontsize=9]
    D2 -> HW2 [label="USB 3.0"  color="#27AE60" fontcolor="#27AE60" fontname="Noto Sans CJK SC" fontsize=9]
}
